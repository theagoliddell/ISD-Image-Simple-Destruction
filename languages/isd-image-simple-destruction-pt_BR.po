#: includes/class-isd-admin.php
msgid "Access denied."
msgstr "Acesso negado."

#: includes/class-isd-admin.php
msgid "Scanning media in the database..."
msgstr "Escaneando mídias no banco de dados..."

#: includes/class-isd-admin.php
msgid "Deleting images... {percent}% completed."
msgstr "Excluindo imagens... {percent}% concluído."

#: includes/class-isd-admin.php
msgid "Cleanup completed successfully!"
msgstr "Limpeza concluída com sucesso!"

#: includes/class-isd-admin.php
msgid "No images found for the selected criteria."
msgstr "Nenhuma imagem encontrada para os critérios selecionados."

#: includes/class-isd-admin.php
msgid "An error occurred during the deletion process."
msgstr "Ocorreu um erro no processo de exclusão."

#: includes/class-isd-admin.php
msgid "Are you sure you want to permanently delete all matching images? This action cannot be undone."
msgstr "Tem certeza de que deseja apagar permanentemente todas as imagens correspondentes? Esta ação não pode ser desfeita."

#: includes/class-isd-admin.php
msgid "Starting deletion of"
msgstr "Iniciando exclusão de"

#: includes/class-isd-admin.php
msgid "Est. size:"
msgstr "Tam. estimado:"

#: includes/class-isd-admin.php
msgid "images"
msgstr "imagens"

#: includes/class-isd-admin.php
msgid "Images deleted:"
msgstr "Imagens apagadas:"

#: includes/class-isd-admin.php
msgid "Space freed so far:"
msgstr "Espaço liberado até agora:"

#: includes/class-isd-admin.php
msgid "Error:"
msgstr "Erro:"

#: includes/class-isd-admin.php
msgid "ISD - Image Simple Destruction"
msgstr "ISD - Image Simple Destruction"

#: includes/class-isd-admin.php
msgid "Image Destruction"
msgstr "Destruição de Imagens"

#: admin/settings-page.php
msgid "Remove media files from old or broken posts to keep your server light and optimized."
msgstr "Apague mídias de postagens antigas ou quebradas para manter seu servidor leve e otimizado."

#: admin/settings-page.php
msgid "Settings saved and applied successfully!"
msgstr "Configurações salvas e aplicadas com sucesso!"

#: admin/settings-page.php
msgid "Automatic Cleanup Settings"
msgstr "Configurações da Limpeza Automática"

#: admin/settings-page.php
msgid "Enable Automatic Cleanup"
msgstr "Habilitar Limpeza Automática"

#: admin/settings-page.php
msgid "Activates daily/periodic automatic cleanup via WP Cron."
msgstr "Ativa a limpeza automática diária/periódica via WP Cron."

#: admin/settings-page.php
msgid "Cleanup Frequency"
msgstr "Frequência da Limpeza"

#: admin/settings-page.php
msgid "Daily"
msgstr "Diariamente"

#: admin/settings-page.php
msgid "Twice a day"
msgstr "Duas vezes ao dia"

#: admin/settings-page.php
msgid "Weekly"
msgstr "Semanalmente"

#: admin/settings-page.php
msgid "Select how often the server will perform the automatic scan."
msgstr "Selecione a frequência com que o servidor fará a varredura automática."

#: admin/settings-page.php
msgid "Delete images from posts published more than:"
msgstr "Excluir imagens de postagens publicadas há mais de:"

#: admin/settings-page.php
msgid "Day(s)"
msgstr "Dia(s)"

#: admin/settings-page.php
msgid "Month(s)"
msgstr "Mês(es)"

#: admin/settings-page.php
msgid "Images from posts published before this limit will be physically removed. The post text remains unchanged."
msgstr "As imagens das postagens publicadas antes desse limite serão removidas fisicamente. O post em texto não é alterado."

#: admin/settings-page.php
msgid "Exclude Categories from Cleanup:"
msgstr "Excluir Categorias da Limpeza:"

#: admin/settings-page.php
msgid "No categories found."
msgstr "Nenhuma categoria encontrada."

#: admin/settings-page.php
msgid "Images from posts belonging to the selected categories will NOT be deleted."
msgstr "Imagens de posts pertencentes às categorias selecionadas NÃO serão excluídas."

#: admin/settings-page.php
msgid "Broken / Orphaned Image Rules"
msgstr "Regras para Imagens Quebradas / Órfãs"

#: admin/settings-page.php
msgid "Remove if the original post was deleted"
msgstr "Remover se o post original foi excluído"

#: admin/settings-page.php
msgid "Deletes images whose source post no longer exists in the database."
msgstr "Exclui imagens cujo post de origem não existe mais no banco de dados."

#: admin/settings-page.php
msgid "Remove from trashed posts"
msgstr "Remover de postagens na lixeira"

#: admin/settings-page.php
msgid "Deletes images from posts that are currently in the Trash."
msgstr "Exclui imagens de postagens que estão atualmente na Lixeira."

#: admin/settings-page.php
msgid "Remove unattached (orphaned) images"
msgstr "Remover imagens não anexadas (órfãs)"

#: admin/settings-page.php
msgid "Deletes media files that are not linked to any post."
msgstr "Exclui mídias na biblioteca que não estão vinculadas a nenhuma postagem."

#: admin/settings-page.php
msgid "Save Settings"
msgstr "Salvar Configurações"

#: admin/settings-page.php
msgid "Manual Cleanup"
msgstr "Limpeza Manual Imediata"

#: admin/settings-page.php
msgid "Run an instant scan using the rules configured above. The process runs safely in small background batches to avoid server overload."
msgstr "Execute uma varredura instantânea com as regras configuradas acima. O processo roda de forma segura em pequenos lotes em segundo plano para evitar sobrecarga no servidor."

#: admin/settings-page.php
msgid "Clean Now"
msgstr "Limpar Agora"

#: admin/settings-page.php
msgid "Starting scan..."
msgstr "Iniciando varredura..."

#: admin/settings-page.php
msgid "Server Status"
msgstr "Status do Servidor"

#: admin/settings-page.php
msgid "Automatic Scheduling"
msgstr "Agendamento Automático"

#: admin/settings-page.php
msgid "Active"
msgstr "Ativo"

#: admin/settings-page.php
msgid "Inactive"
msgstr "Inativo"

#: admin/settings-page.php
msgid "Cron Frequency"
msgstr "Frequência do Cron"

#: admin/settings-page.php
msgid "Next Scheduled Run"
msgstr "Próxima Execução Agendada"

#: admin/settings-page.php
msgid "No active schedule"
msgstr "Sem agendamento ativo"

#: admin/settings-page.php
msgid "Expiration Filter"
msgstr "Filtro de Expiração"

#: admin/settings-page.php
msgid "Recent Cleanup History"
msgstr "Histórico de Limpezas Recentes"

#: admin/settings-page.php
msgid "No cleanups recorded yet."
msgstr "Nenhuma limpeza registrada ainda."

#: admin/settings-page.php
msgid "Date/Time"
msgstr "Data/Hora"

#: admin/settings-page.php
msgid "Type"
msgstr "Tipo"

#: admin/settings-page.php
msgid "Deleted"
msgstr "Qtd. Apagada"

#: admin/settings-page.php
msgid "Space Saved"
msgstr "Espaço Salvo"

#: admin/settings-page.php
msgid "Auto"
msgstr "Auto"

#: admin/settings-page.php
msgid "Manual"
msgstr "Manual"
